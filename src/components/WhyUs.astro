---
const reasons = [
	{ title: "Tăng trưởng thật", text: "Tập trung tối ưu chuyển đổi mang lại doanh thu thực tế cho doanh nghiệp.", color: "bg-[#02b3fd]", textBg: "bg-[#02b3fd]/10", border: "border-[#02b3fd]/20" },
	{ title: "Nắm bắt xu thế nhanh", text: "Sản xuất nội dung bắt trend nhanh nhạy, hiện đại, thu hút tương tác tốt.", color: "bg-[#568fca]", textBg: "bg-[#568fca]/10", border: "border-[#568fca]/20" },
	{ title: "Target chính xác", text: "Tối ưu ngân sách quảng cáo, tiếp cận chính xác tệp khách hàng mục tiêu.", color: "bg-[#ff811b]", textBg: "bg-[#ff811b]/10", border: "border-[#ff811b]/20" },
	{ title: "Đồng hành 24/7", text: "Hỗ trợ kỹ thuật, tối ưu hóa chiến dịch liên tục để đảm bảo hiệu suất tốt nhất.", color: "bg-[#215abd]", textBg: "bg-[#215abd]/10", border: "border-[#215abd]/20" },
];
---
<section class="relative overflow-hidden py-20 lg:py-32 bg-gradient-to-tr from-[#f0fdfa] via-[#f0f9ff] to-[#eff6ff] border-y border-[#02b3fd]/10">
	<!-- Visual blobs -->
	<div class="absolute w-64 h-64 bg-[#02b3fd]/10 rounded-full blur-2xl -top-10 -left-10"></div>
	<div class="absolute w-80 h-80 bg-[#568fca]/10 rounded-full blur-2xl -bottom-10 -right-10"></div>

	<div class="section-shell relative z-10">
		<div class="reveal text-center max-w-2xl mx-auto space-y-4 mb-16">
			<div class="tag">✨ Vì sao chọn KIGI?</div>
			<h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl text-deep-navy">Khác biệt vượt trội từ tư duy giải pháp</h2>
		</div>

		<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
			{reasons.map((reason, index) => (
				<article class={`reveal rounded-2xl border ${reason.border} ${reason.textBg} p-8 shadow-[0_12px_28px_rgba(15,23,42,0.04)] hover:shadow-[0_20px_45px_rgba(2,179,253,0.12)] hover:-translate-y-1.5 transition-all duration-300 space-y-6`} style={`transition-delay: ${index * 80}ms`}>
					<span class={`flex size-10 items-center justify-center rounded-xl text-white font-bold text-sm ${reason.color} shadow-md`}>
						0{index + 1}
					</span>
					<div>
						<h3 class="text-xl font-bold text-deep-navy">{reason.title}</h3>
						<p class="mt-3 text-sm text-slate-600 leading-relaxed">{reason.text}</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>
