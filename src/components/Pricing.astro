---
const featuredServices = [
	{
		title: "Quản lý Fanpage Chuyên Nghiệp",
		price: "Thỏa thuận",
		popular: false,
		items: ["Lên kế hoạch nội dung chi tiết theo tháng", "Thiết kế hình ảnh thương hiệu độc quyền", "Sản xuất video ngắn Reels/TikTok", "Đăng bài chuẩn SEO và tương tác khách hàng"],
	},
	{
		title: "Marketing Tổng Thể Doanh Nghiệp",
		price: "Khuyên dùng",
		popular: true,
		items: ["Tối ưu Website và SEO Google", "Vận hành đa kênh Facebook, Zalo, TikTok", "Chạy quảng cáo Facebook Ads / Google Ads", "Báo cáo số liệu minh bạch hàng tuần/tháng"],
	},
	{
		title: "Media & Video Production",
		price: "Thỏa thuận",
		popular: false,
		items: ["Quay dựng video ngắn TikTok viral", "Sản xuất video giới thiệu sản phẩm/dịch vụ", "Chụp ảnh sản phẩm chuyên nghiệp", "Hỗ trợ viết kịch bản phân cảnh chi tiết"],
	},
];
---
<section class="py-20 lg:py-32 bg-gradient-to-b from-[#f2f3ff] to-[#faf8ff] border-t border-[#02b3fd]/10">
	<div class="section-shell">
		<div class="reveal text-center max-w-2xl mx-auto space-y-4 mb-16">
			<div class="tag">✨ Bảng giá nổi bật</div>
			<h2 class="text-3xl font-extrabold tracking-tight text-deep-navy sm:text-4xl">Lựa chọn gói dịch vụ tối ưu</h2>
		</div>

		<div class="grid gap-8 lg:grid-cols-3">
			{featuredServices.map((pkg, index) => (
				<article class={`reveal k-card relative flex flex-col justify-between h-full p-8 ${pkg.popular ? "border-2 border-[#02b3fd] shadow-[0_25px_55px_rgba(2,179,253,0.25)]" : ""}`} style={`transition-delay: ${index * 80}ms`}>
					{pkg.popular && (
						<span class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-[#568fca] to-[#02b3fd] px-4 py-1 text-xs font-extrabold text-white uppercase tracking-wider shadow-md">
							Khuyên dùng
						</span>
					)}
					<div class="space-y-6">
						<div>
							<p class="text-xs font-extrabold tracking-widest text-[#02b3fd] uppercase">Gói 0{index + 1}</p>
							<h3 class="mt-2 text-2xl font-black text-deep-navy leading-snug">{pkg.title}</h3>
						</div>
						<div class="py-2 border-y border-slate-100 flex items-baseline gap-1">
							<span class="text-xl font-bold text-[#02b3fd]">{pkg.price}</span>
						</div>
						<ul class="space-y-4 text-sm text-slate-600">
							{pkg.items.map((item) => (
								<li class="flex items-start gap-3">
									<span class="mt-1 flex size-2 shrink-0 rounded-full bg-[#02b3fd]"></span>
									<span>{item}</span>
								</li>
							))}
						</ul>
					</div>
					<!-- Đồng bộ nút Đăng ký (Primary & Outline đồng bộ đúng 52px chiều cao) -->
					<div class="pt-8">
						{pkg.popular ? (
							<a href="#contact" class="btn-premium-primary w-full">
								Đăng ký ngay
							</a>
						) : (
							<a href="#contact" class="btn-premium-outline w-full">
								Đăng ký ngay
							</a>
						)}
					</div>
				</article>
			))}
		</div>
	</div>
</section>
