---
const iconAttrs = 'viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"';
const services = [
	{
		id: "website-design",
		code: "WEB",
		title: "Thiết kế Website chuẩn SEO",
		text: "Giao diện độc bản, tối ưu trải nghiệm UI/UX mượt mà và chuẩn hóa SEO hỗ trợ tăng trưởng doanh thu vượt trội.",
		accent: "from-[#02b3fd] to-[#00b3ff]",
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-6 text-[#02b3fd]"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`
	},
	{
		id: "content-creation",
		code: "CONTENT",
		title: "Sáng tạo nội dung",
		text: "Xây dựng kịch bản, sản xuất hình ảnh bắt mắt, làm video ngắn TikTok/Reels chuyên nghiệp thu hút khách hàng.",
		accent: "from-[#568fca] to-[#02b3fd]",
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-6 text-[#568fca]"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`
	},
	{
		id: "ads-service",
		code: "ADS",
		title: "Chạy quảng cáo tối ưu",
		text: "Triển khai chiến dịch Facebook Ads, Google Ads, TikTok Ads thông minh giúp tiếp cận đúng tệp khách hàng tiềm năng.",
		accent: "from-[#ff811b] to-[#ffd21e]",
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-6 text-[#ff811b]"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`
	},
	{
		id: "brand-service",
		code: "BRAND",
		title: "Xây dựng thương hiệu",
		text: "Tư vấn bộ nhận diện thương hiệu nhất quán, khác biệt, định vị giá trị lõi giúp doanh nghiệp nổi bật trên thị trường.",
		accent: "from-[#215abd] to-[#568fca]",
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-6 text-[#215abd]"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
	},
];
---
<section id="services" class="py-20 lg:py-32 bg-white/40 backdrop-blur-sm">
	<div class="section-shell">
		<!-- Section Header -->
		<div class="reveal flex flex-col justify-between gap-6 md:flex-row md:items-end mb-16">
			<div class="space-y-4">
				<div class="tag">✨ Dịch vụ toàn diện</div>
				<h2 class="text-3xl font-extrabold tracking-tight text-deep-navy sm:text-4xl">Giải pháp Marketing đa nền tảng</h2>
			</div>
			<a href="#contact" class="btn-premium-outline">
				Tư vấn gói giải pháp
			</a>
		</div>

		<!-- Grid Cards -->
		<div class="grid grid-cols-2 gap-4 md:grid-cols-2 lg:grid-cols-4">
			{services.map((service, index) => (
				<article id={service.id} class="reveal k-card overflow-hidden flex flex-col justify-between h-full" style={`transition-delay: ${index * 80}ms`}>
					<div class="p-4 sm:p-8 space-y-4 sm:space-y-6">
						<div class="inline-flex rounded-xl bg-white p-2 sm:p-3.5 shadow-sm border border-slate-100" set:html={service.icon}></div>
						<div class="space-y-1 sm:space-y-3">
							<h3 class="text-base sm:text-xl font-bold text-deep-navy leading-snug">{service.title}</h3>
							<p class="text-xs sm:text-sm text-slate-500 leading-relaxed">{service.text}</p>
						</div>
					</div>
					<div class={`h-1.5 w-full bg-gradient-to-r ${service.accent}`}></div>
				</article>
			))}
		</div>

		<style is:global>
			.k-card svg {
				width: 1.25rem !important;
				height: 1.25rem !important;
			}
			@media (min-width: 640px) {
				.k-card svg {
					width: 1.5rem !important;
					height: 1.5rem !important;
				}
			}
		</style>
	</div>
</section>
