---
const navItems = [
	{ label: "Trang chủ", href: "#top", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="m3 11 9-8 9 8"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/></svg>` },
	{ label: "Về KIGI", href: "#about", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
	{ label: "Dịch vụ", href: "#services", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M8 22h8"/><path d="M12 18v4"/><path d="m8 9 2.2 2.2L8 13.4"/><path d="M14 13h3"/></svg>` },
	{ label: "Quy trình", href: "#workflow", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>` },
	{ label: "Dự án", href: "#projects", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>` },
	{ label: "Liên hệ", href: "#contact", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.89.66 2.77a2 2 0 0 1-.45 2.11L8.1 9.9a16 16 0 0 0 6 6l1.3-1.22a2 2 0 0 1 2.11-.45c.88.31 1.81.53 2.77.66A2 2 0 0 1 22 16.92z"/></svg>` },
];
---

<header class="fixed left-0 right-0 top-0 z-50 px-4 py-4 lg:px-8">
	<div class="mx-auto max-w-7xl rounded-full border border-white/60 bg-white/85 px-4 py-2 sm:px-6 sm:py-2.5 shadow-[0_20px_50px_rgba(15,23,42,0.06),_0_10px_30px_rgba(2,179,253,0.05)] backdrop-blur-xl lg:px-8">
		<div class="flex items-center justify-between gap-4 w-full">
			<div class="flex items-center gap-3">
				<!-- Menu Toggle Mobile (Đặt bên trái ngoài cùng trên di động) -->
				<button class="button-focus menu-toggle grid size-10 place-items-center rounded-xl border border-white/40 bg-[#e0f7fa] text-[#02b3fd] xl:hidden shrink-0" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Mở menu">
					<svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
						<path d="M4 7h16"></path>
						<path d="M4 12h16"></path>
						<path d="M4 17h16"></path>
					</svg>
				</button>

				<!-- Logo -->
				<a href="#top" class="button-focus flex items-center gap-2.5 rounded-full hover:opacity-95 transition-opacity shrink-0">
					<img src="/logo.jpg" alt="KIGI Agency Logo" class="h-10 w-auto rounded-lg object-contain shadow-sm border border-white/40" />
					<span class="text-lg sm:text-xl font-black tracking-wider text-deep-navy whitespace-nowrap">KIGI Agency</span>
				</a>
			</div>

			<!-- Menu Desktop -->
			<nav class="hidden items-center gap-1 xl:gap-2 text-[14px] font-extrabold uppercase tracking-wider xl:flex">
				{navItems.map((item) => (
					<a class="button-focus flex items-center gap-2 rounded-xl px-3 py-2 2xl:px-4 text-deep-navy/80 transition-all hover:bg-[#02b3fd]/15 hover:text-[#02b3fd]" href={item.href}>
						<span class="menu-icon" set:html={item.icon}></span>
						<span class="whitespace-nowrap">{item.label}</span>
					</a>
				))}
			</nav>

			<!-- Action Buttons (Nút vừa phải trên Navbar) -->
			<div class="flex items-center gap-2 shrink-0">
				<a href="#contact" class="hidden sm:inline-flex btn btn-primary rounded-full btn-sm sm:btn-md h-[44px] !min-h-[44px] px-6 shadow-[0_4px_14px_rgba(2,179,253,0.35)] hover:scale-105 transition-all text-white border-0 bg-gradient-to-r from-[#568fca] to-[#02b3fd] items-center justify-center font-bold text-sm">
					Liên hệ ngay
				</a>
			</div>
		</div>
	</div>

	<!-- Mobile Menu Drawer (Lớp phủ nền mờ và Drawer panel trượt từ cạnh trái) -->
	<div class="drawer-container fixed inset-0 z-50 pointer-events-none xl:hidden">
		<!-- Overlay -->
		<div class="drawer-overlay fixed inset-0 bg-slate-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-300 pointer-events-none"></div>

		<!-- Drawer Panel -->
		<aside class="drawer-panel fixed top-0 bottom-0 left-0 z-50 w-[310px] max-w-[calc(100%-3rem)] bg-white/95 backdrop-blur-xl p-6 shadow-2xl transition-transform duration-300 -translate-x-full border-r border-white/40 flex flex-col justify-between">
			<div class="space-y-8">
				<!-- Header drawer -->
				<div class="flex items-center justify-between gap-4 border-b border-slate-100 pb-4">
					<div class="flex items-center gap-2.5">
						<img src="/logo.jpg" alt="KIGI Agency Logo" class="h-10 w-auto rounded-lg object-contain shadow-sm border border-slate-200" />
						<div class="leading-none">
							<p class="text-lg font-black tracking-wider text-deep-navy">KIGI</p>
							<p class="text-[9px] font-bold uppercase tracking-widest text-[#02b3fd] mt-0.5">Agency</p>
						</div>
					</div>
					<!-- Nút tắt Close (X) -->
					<button class="drawer-close button-focus grid size-9 place-items-center rounded-full border border-slate-100 bg-slate-50 hover:bg-[#02b3fd]/15 hover:text-[#02b3fd] transition-all text-slate-500" type="button" aria-label="Đóng menu">
						<svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
					</button>
				</div>

				<!-- Menu Links (Dạng hàng dọc) -->
				<nav class="flex flex-col gap-1.5">
					{navItems.map((item) => (
						<a class="button-focus flex items-center gap-4 rounded-2xl px-4 py-3.5 text-sm font-extrabold uppercase tracking-wider text-deep-navy transition-all hover:bg-[#02b3fd]/10 hover:text-[#02b3fd] border border-transparent hover:border-[#02b3fd]/10" href={item.href}>
							<span class="menu-icon text-slate-400" set:html={item.icon}></span>
							<span class="whitespace-nowrap">{item.label}</span>
						</a>
					))}
				</nav>
			</div>

			<!-- Footer drawer -->
			<div class="border-t border-slate-100 pt-6">
				<a href="#contact" class="btn-premium-primary w-full flex items-center justify-center gap-2">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.89.66 2.77a2 2 0 0 1-.45 2.11L8.1 9.9a16 16 0 0 0 6 6l1.3-1.22a2 2 0 0 1 2.11-.45c.88.31 1.81.53 2.77.66A2 2 0 0 1 22 16.92z"/></svg>
					Liên hệ ngay
				</a>
			</div>
		</aside>
	</div>
</header>

<script>
	function initDrawerMenu() {
		const menuButton = document.querySelector(".menu-toggle");
		const closeButton = document.querySelector(".drawer-close");
		const drawerOverlay = document.querySelector(".drawer-overlay");
		const drawerPanel = document.querySelector(".drawer-panel");
		const drawerContainer = document.querySelector(".drawer-container");
		const drawerLinks = document.querySelectorAll(".drawer-panel a");

		function openMenu() {
			if (drawerContainer) drawerContainer.classList.remove("pointer-events-none");
			drawerOverlay?.classList.remove("opacity-0", "pointer-events-none");
			drawerOverlay?.classList.add("opacity-100", "pointer-events-auto");
			drawerPanel?.classList.remove("-translate-x-full");
			drawerPanel?.classList.add("translate-x-0");
			menuButton?.setAttribute("aria-expanded", "true");
			document.body.style.overflow = "hidden"; // Ngăn cuộn trang
		}

		function closeMenu() {
			drawerOverlay?.classList.remove("opacity-100", "pointer-events-auto");
			drawerOverlay?.classList.add("opacity-0", "pointer-events-none");
			drawerPanel?.classList.remove("translate-x-0");
			drawerPanel?.classList.add("-translate-x-full");
			menuButton?.setAttribute("aria-expanded", "false");
			document.body.style.overflow = ""; // Khôi phục cuộn

			// Đợi hiệu ứng kết thúc rồi ẩn vùng chứa click
			setTimeout(() => {
				if (drawerPanel && !drawerPanel.classList.contains("translate-x-0")) {
					drawerContainer?.classList.add("pointer-events-none");
				}
			}, 300);
		}

		menuButton?.addEventListener("click", openMenu);
		closeButton?.addEventListener("click", closeMenu);
		drawerOverlay?.addEventListener("click", closeMenu);

		drawerLinks.forEach((link) => {
			link.addEventListener("click", closeMenu);
		});
	}

	// Khởi chạy
	initDrawerMenu();

	// Tương thích với SPA transitions của Astro (nếu có)
	document.addEventListener("astro:after-swap", initDrawerMenu);
</script>
