---
const clients = ["NHA TRANG FOOD", "VIET SMILE", "KATI BEAUTY", "SÀI GÒN MEDIA", "VIỆT PHÁT GROUP", "NICE TRAVEL"];
---
<section class="py-16 bg-[#faf8ff] border-y border-slate-100">
	<div class="section-shell grid items-center gap-12 lg:grid-cols-[.8fr_1.2fr]">
		<div class="reveal space-y-3">
			<div class="tag">Đối tác</div>
			<h2 class="text-3xl font-extrabold text-deep-navy">Các thương hiệu tin cậy đồng hành</h2>
		</div>
		<div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
			{clients.map((client, index) => (
				<div class="reveal glass-panel flex min-h-20 items-center justify-center rounded-2xl border border-white/60 p-4 text-center font-bold text-slate-700 shadow-sm" style={`transition-delay: ${index * 55}ms`}>
					{client}
				</div>
			))}
		</div>
	</div>
</section>
