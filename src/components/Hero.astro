---
---
<section class="relative overflow-hidden pb-24 pt-32 lg:pb-36 lg:pt-44">
	<div class="section-shell relative grid items-center gap-12 lg:grid-cols-[1.1fr_.9fr]">
		<!-- Text Block -->
		<div class="reveal space-y-6 relative z-10">
			<div class="tag">✨ KIGI Agency</div>
			<h1 class="text-4xl font-extrabold tracking-tight text-deep-navy sm:text-5xl lg:text-6xl leading-[1.15]">
				Sáng tạo để <br />
				<span class="text-gradient">Tăng trưởng</span> <br />
				bền vững
			</h1>
			<p class="max-w-xl text-base leading-relaxed text-slate-600 md:text-lg">
				KIGI Agency đồng hành cùng doanh nghiệp kiến tạo thương hiệu vững mạnh trên các nền tảng kỹ thuật số (Facebook, TikTok, Google & Website) bằng tư duy đột phá, thực chiến và sáng tạo.
			</p>
			
			<!-- Nút Premium đồng bộ 52px -->
			<div class="flex flex-wrap gap-4 pt-2">
				<a class="btn-premium-primary" href="#services">
					Khám phá dịch vụ
				</a>
				<a class="btn-premium-outline" href="#projects">
					Xem dự án thực tế
				</a>
			</div>
			
			<!-- Stats Badges -->
			<div class="grid grid-cols-3 gap-4 pt-6 max-w-md">
				{[
					["50+", "Khách hàng", "text-[#02b3fd]"],
					["98%", "Hài lòng", "text-[#568fca]"],
					["24/7", "Đồng hành", "text-[#ff811b]"],
				].map(([value, desc, colorClass]) => (
					<div class="rounded-xl border border-white/55 bg-white/50 p-4 shadow-[0_12px_28px_rgba(2,179,253,0.06)] backdrop-blur-sm text-center">
						<p class={`text-2xl font-black ${colorClass}`}>{value}</p>
						<p class="mt-1 text-[11px] font-bold uppercase tracking-wider text-slate-500">{desc}</p>
					</div>
				))}
			</div>
		</div>

		<!-- Hero Visual Block -->
		<div class="reveal relative" style="transition-delay: 150ms">
			<!-- Ambient Glow -->
			<div class="absolute -inset-4 bg-gradient-to-r from-[#568fca] to-[#02b3fd] rounded-[2.5rem] blur-3xl opacity-20 animate-pulse-slow"></div>
			<!-- Glass Container for Image -->
			<div class="glass-panel rounded-3xl p-4 relative shadow-[0_30px_60px_rgba(2,179,253,0.22)] border border-white/60 transition-transform duration-500 hover:-translate-y-2">
				<!-- Khung ảnh có overflow-hidden để bo góc ảnh tròn đẹp -->
				<div class="overflow-hidden rounded-2xl aspect-[4/3] w-full">
					<img class="w-full h-full object-cover" src="/images/hero.jpg" alt="Đội ngũ sáng tạo KIGI Agency" />
				</div>
				
				<!-- Floating Card 1 -->
				<div class="absolute -bottom-6 -left-6 bg-white/95 backdrop-blur-md border border-white/50 rounded-2xl p-4 shadow-[0_15px_30px_rgba(2,179,253,0.18)] flex items-center gap-4 animate-bounce z-20" style="animation-duration: 4s">
					<div class="bg-[#e0f7fa] p-3 rounded-xl text-[#02b3fd] flex items-center justify-center">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M23 6 13.5 15.5 8.5 10.5 1 18"/><path d="M17 6h6v6"/></svg>
					</div>
					<div>
						<p class="font-black text-deep-navy text-sm">Tăng trưởng SEO</p>
						<p class="text-xs font-semibold text-[#02b3fd]">+250% Traffic</p>
					</div>
				</div>

				<!-- Floating Card 2 -->
				<div class="absolute -top-6 -right-6 bg-white/95 backdrop-blur-md border border-white/50 rounded-2xl p-4 shadow-[0_15px_30px_rgba(86,143,202,0.15)] flex items-center gap-4 animate-bounce z-20 hidden md:flex" style="animation-duration: 5s">
					<div class="bg-[#fef3c7] p-3 rounded-xl text-[#ff811b] flex items-center justify-center">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
					</div>
					<div>
						<p class="font-black text-deep-navy text-sm font-sans">Doanh số Quảng cáo</p>
						<p class="text-xs font-semibold text-[#ff811b] font-sans">+180% Đơn hàng</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
