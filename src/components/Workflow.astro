---
const workflow = [
	{ step: "01", title: "Tiếp nhận & Khảo sát", text: "Lắng nghe nhu cầu, phân tích đối thủ cạnh tranh và khảo sát thị trường.", gradient: "from-[#02b3fd]/20 to-[#568fca]/10" },
	{ step: "02", title: "Lên chiến lược", text: "Đề xuất kế hoạch triển khai chi tiết, bảng giá và thời gian hoàn thành dự kiến.", gradient: "from-[#568fca]/20 to-[#02b3fd]/10" },
	{ step: "03", title: "Sản xuất & Triển khai", text: "Thiết kế giao diện, lập trình tính năng, viết content và thiết kế hình ảnh.", gradient: "from-[#ff811b]/20 to-[#ffd21e]/10" },
	{ step: "04", title: "Nghiệm thu & Tối ưu", text: "Kiểm thử toàn diện, tối ưu hóa tốc độ tải trang, SEO và bàn giao tài liệu hướng dẫn.", gradient: "from-[#215abd]/20 to-[#02b3fd]/10" },
];
---
<section id="workflow" class="py-20 lg:py-32 bg-white/50 backdrop-blur-sm relative">
	<div class="section-shell relative z-10">
		<!-- Section Header -->
		<div class="reveal text-center max-w-2xl mx-auto space-y-4 mb-16">
			<div class="tag">Quy trình chuẩn hóa</div>
			<h2 class="text-3xl font-extrabold tracking-tight text-deep-navy sm:text-4xl">4 bước hợp tác hiệu quả</h2>
		</div>

		<!-- Process Steps -->
		<div class="grid gap-8 lg:grid-cols-4 relative">
			{workflow.map((item, index) => (
				<article class="reveal k-card relative h-full p-8 flex flex-col justify-between" style={`transition-delay: ${index * 80}ms`}>
					<span class="absolute -right-2 -top-4 text-7xl font-extrabold text-slate-200/40 select-none z-0">{item.step}</span>
					<div class="relative z-10 space-y-4">
						<span class={`inline-block px-3 py-1 bg-gradient-to-r ${item.gradient} text-[#0f172a] text-xs font-bold rounded-lg uppercase tracking-wider`}>Bước {item.step}</span>
						<h3 class="text-lg font-bold text-deep-navy pt-2">{item.title}</h3>
						<p class="text-sm text-slate-500 leading-relaxed">{item.text}</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>
