---
const iconAttrs = 'viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"';
const contactItems = [
	{ label: "Hotline", text: "0563.555.535", href: "tel:0563555535", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-5 text-[#02b3fd]"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.89.66 2.77a2 2 0 0 1-.45 2.11L8.1 9.9a16 16 0 0 0 6 6l1.3-1.22a2 2 0 0 1 2.11-.45c.88.31 1.81.53 2.77.66A2 2 0 0 1 22 16.92z"/></svg>` },
	{ label: "Email", text: "info@kigiagency.com", href: "mailto:info@kigiagency.com", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-5 text-[#568fca]"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>` },
	{ label: "Website", text: "www.kigiagency.com", href: "https://kigiagency.com/", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-5 text-[#ff811b]"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 0 20"/><path d="M12 2a15.3 15.3 0 0 0 0 20"/></svg>` },
	{ label: "Địa chỉ", text: "Số 25 - 26 Nguyễn Đình Chiểu, Phường Vĩnh Phước, TP. Nha Trang, Khánh Hòa", href: "", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-5 text-[#215abd]"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>` },
];
---
<section id="contact" class="py-20 lg:py-32 bg-white">
	<div class="section-shell grid gap-12 lg:grid-cols-[.9fr_1.1fr]">
		<!-- Contact Info Block -->
		<div class="reveal space-y-8">
			<div class="space-y-4">
				<div class="tag">✨ Liên hệ</div>
				<h2 class="text-3xl font-extrabold text-deep-navy sm:text-4xl">Nhận tư vấn chiến lược miễn phí</h2>
				<p class="text-slate-500 leading-relaxed max-w-md">
					Vui lòng để lại thông tin liên lạc của bạn. Đội ngũ tư vấn của KIGI Agency sẽ nhanh chóng liên hệ hỗ trợ trong thời gian sớm nhất.
				</p>
			</div>

			<div class="grid gap-4 max-w-md">
				{contactItems.map((item) => (
					<div class="flex gap-4 rounded-2xl border border-white/60 bg-white/80 p-5 shadow-[0_12px_28px_rgba(15,23,42,0.06),_0_4px_12px_rgba(2,179,253,0.03)] backdrop-blur-md transition-all duration-300 hover:shadow-[0_18px_38px_rgba(2,179,253,0.1)] hover:-translate-y-0.5">
						<span class="grid size-11 shrink-0 place-items-center rounded-xl bg-[#e0f7fa] text-[#02b3fd] shadow-sm border border-[#02b3fd]/10">
							<span class="contact-icon" set:html={item.icon}></span>
						</span>
						<div class="space-y-1">
							<p class="text-xs font-bold uppercase tracking-wider text-slate-400">{item.label}</p>
							{item.href ? (
								<a class="block font-bold text-deep-navy hover:text-[#02b3fd] transition-colors break-all" href={item.href}>{item.text}</a>
							) : (
								<p class="font-bold text-deep-navy leading-relaxed">{item.text}</p>
							)}
						</div>
					</div>
				))}
			</div>
		</div>

		<!-- Contact Form Block -->
		<form class="reveal k-card p-8 space-y-6" action="mailto:info@kigiagency.com" method="post" enctype="text/plain">
			<h3 class="text-2xl font-bold text-deep-navy">Gửi thông tin cho chúng tôi</h3>
			
			<div class="space-y-2">
				<label class="text-sm font-bold text-slate-600" for="name">Họ và tên</label>
				<input id="name" name="name" class="input input-bordered w-full rounded-xl bg-white border-slate-200 focus:border-[#02b3fd] outline-none" type="text" required />
			</div>
			
			<div class="space-y-2">
				<label class="text-sm font-bold text-slate-600" for="phone">Số điện thoại</label>
				<input id="phone" name="phone" class="input input-bordered w-full rounded-xl bg-white border-slate-200 focus:border-[#02b3fd] outline-none" type="tel" required />
			</div>
			
			<div class="space-y-2">
				<label class="text-sm font-bold text-slate-600" for="message">Nội dung yêu cầu</label>
				<textarea id="message" name="message" class="textarea textarea-bordered min-h-32 w-full rounded-xl bg-white border-slate-200 focus:border-[#02b3fd] outline-none" required></textarea>
			</div>
			
			<!-- Đồng bộ nút Gửi Form (Primary 52px) -->
			<button class="btn-premium-primary w-full" type="submit">
				Gửi thông tin ngay
			</button>
		</form>
	</div>
</section>
