---

<Layout>
	<main id="top" class="relative overflow-hidden">
		<!-- Background Grid Pattern -->
		<div class="absolute inset-0 bg-grid-pattern z-0 pointer-events-none"></div>
		<div class="absolute inset-0 bg-dots-pattern z-0 pointer-events-none opacity-40"></div>

		<!-- Glow Blobs for Visual Aesthetics (Rực rỡ, nhiều màu sắc) -->
		<div class="glow-blob bg-[#00bcd4]/20 w-[400px] h-[400px] top-[-100px] left-[-100px]"></div>
		<div class="glow-blob bg-[#ff37b7]/15 w-[500px] h-[500px] top-[400px] right-[-150px]"></div>
		<div class="glow-blob bg-[#ff811b]/10 w-[450px] h-[450px] top-[1400px] left-[10%]"></div>
		<div class="glow-blob bg-[#215abd]/15 w-[500px] h-[500px] top-[2500px] right-[5%]"></div>
		<div class="glow-blob bg-[#00bcd4]/15 w-[450px] h-[450px] top-[3800px] left-[-100px]"></div>
		<div class="glow-blob bg-[#ff37b7]/10 w-[500px] h-[500px] top-[5000px] right-[10%]"></div>

		<!-- Header/Navigation Bar -->
		<header class="fixed left-0 right-0 top-0 z-50 px-4 py-4 lg:px-8">
			<div class="mx-auto max-w-7xl rounded-2xl border border-white/40 bg-white/80 px-4 py-3 shadow-[0_10px_30px_rgba(0,188,212,0.08)] backdrop-blur-xl lg:px-6">
				<div class="flex items-center justify-between gap-4">
					<!-- Logo -->
					<a href="#top" class="button-focus flex items-center gap-3 rounded-xl hover:opacity-95 transition-opacity">
						<img src="/logo.jpg" alt="KIGI Agency Logo" class="h-10 w-auto rounded-lg object-contain shadow-sm border border-white/40" />
						<span class="leading-none hidden sm:inline-block">
							<span class="block text-lg font-black tracking-wider text-deep-navy">KIGI</span>
							<span class="mt-0.5 block text-[10px] font-extrabold uppercase tracking-[0.2em] text-[#00bcd4]">Agency</span>
						</span>
					</a>

					<!-- Menu Desktop -->
					<nav class="hidden items-center gap-1 text-[13px] font-bold uppercase tracking-wider 2xl:flex">
						{navItems.map((item) => (
							<a class="button-focus flex items-center gap-2 rounded-xl px-4 py-2 text-deep-navy/80 transition-all hover:bg-[#00bcd4]/15 hover:text-[#00bcd4]" href={item.href}>
								<span class="menu-icon" set:html={item.icon}></span>
								<span class="whitespace-nowrap">{item.label}</span>
							</a>
						))}
					</nav>

					<!-- Action Buttons -->
					<div class="flex items-center gap-2">
						<a href="#contact" class="btn btn-primary rounded-full btn-sm sm:btn-md shadow-[0_4px_14px_rgba(0,188,212,0.4)] hover:scale-105 transition-all text-white border-0 bg-gradient-to-r from-[#00bcd4] to-[#00b3ff]">
							Liên hệ ngay
						</a>
						<!-- Menu Toggle Mobile -->
						<button class="button-focus menu-toggle grid size-10 place-items-center rounded-xl border border-white/40 bg-[#e0f7fa] text-[#00bcd4] 2xl:hidden" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Mở menu">
							<svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
								<path d="M4 7h16"></path>
								<path d="M4 12h16"></path>
								<path d="M4 17h16"></path>
							</svg>
						</button>
					</div>
				</div>

				<!-- Mobile Menu -->
				<nav id="mobile-menu" class="mobile-menu hidden border-t border-white/20 pt-3 mt-3 2xl:hidden">
					<div class="grid gap-2 sm:grid-cols-2">
						{navItems.map((item) => (
							<a class="button-focus flex items-center gap-3 rounded-xl bg-white/50 px-4 py-3 text-sm font-bold uppercase tracking-wider text-deep-navy transition hover:bg-[#00bcd4] hover:text-white" href={item.href}>
								<span class="menu-icon" set:html={item.icon}></span>
								<span>{item.label}</span>
							</a>
						))}
					</div>
				</nav>
			</div>
		</header>

		<!-- Hero Section -->
		<section class="relative overflow-hidden pb-24 pt-32 lg:pb-36 lg:pt-44">
			<div class="section-shell relative grid items-center gap-12 lg:grid-cols-[1.1fr_.9fr]">
				<!-- Text Block -->
				<div class="reveal space-y-6 relative z-10">
					<div class="tag">KIGI Agency</div>
					<h1 class="text-4xl font-extrabold tracking-tight text-deep-navy sm:text-5xl lg:text-6xl leading-[1.15]">
						Sáng tạo để <br />
						<span class="text-gradient">Tăng trưởng</span> <br />
						bền vững
					</h1>
					<p class="max-w-xl text-base leading-relaxed text-slate-600 md:text-lg">
						KIGI Agency đồng hành cùng doanh nghiệp kiến tạo thương hiệu vững mạnh trên các nền tảng kỹ thuật số (Facebook, TikTok, Google & Website) bằng tư duy đột phá, thực chiến và sáng tạo.
					</p>
					<div class="flex flex-wrap gap-4 pt-2">
						<a class="btn btn-primary rounded-full px-8 text-white bg-gradient-to-r from-[#ff37b7] to-[#00bcd4] shadow-[0_4px_20px_rgba(255,55,183,0.3)] border-0 hover:shadow-lg hover:scale-105 transition-all" href="#services">
							Khám phá dịch vụ
						</a>
						<a class="btn btn-outline rounded-full px-8 border-slate-300 hover:bg-slate-100 hover:text-deep-navy transition-all" href="#projects">
							Xem dự án thực tế
						</a>
					</div>
					
					<!-- Stats Badges -->
					<div class="grid grid-cols-3 gap-4 pt-6 max-w-md">
						{[
							["50+", "Khách hàng", "text-[#00bcd4]"],
							["98%", "Hài lòng", "text-[#ff37b7]"],
							["24/7", "Đồng hành", "text-[#ff811b]"],
						].map(([value, desc, colorClass]) => (
							<div class="rounded-xl border border-white/50 bg-white/50 p-4 shadow-[0_10px_25px_rgba(0,188,212,0.04)] backdrop-blur-sm text-center">
								<p class={`text-2xl font-black ${colorClass}`}>{value}</p>
								<p class="mt-1 text-[11px] font-bold uppercase tracking-wider text-slate-500">{desc}</p>
							</div>
						))}
					</div>
				</div>

				<!-- Hero Visual Block -->
				<div class="reveal relative" style="transition-delay: 150ms">
					<!-- Ambient Glow -->
					<div class="absolute -inset-4 bg-gradient-to-r from-[#ff37b7] to-[#00bcd4] rounded-[2.5rem] blur-3xl opacity-20 animate-pulse-slow"></div>
					<!-- Glass Container for Image -->
					<div class="glass-panel rounded-3xl p-4 relative shadow-[0_20px_50px_rgba(0,188,212,0.15)] border border-white/60 transition-transform duration-500 hover:-translate-y-2">
						<!-- Khung ảnh có overflow-hidden để bo góc ảnh tròn đẹp -->
						<div class="overflow-hidden rounded-2xl aspect-[4/3] w-full">
							<img class="w-full h-full object-cover" src="/images/hero.jpg" alt="Đội ngũ sáng tạo KIGI Agency" />
						</div>
						
						<!-- Floating Card 1 -->
						<div class="absolute -bottom-6 -left-6 bg-white/95 backdrop-blur-md border border-white/50 rounded-2xl p-4 shadow-xl flex items-center gap-4 animate-bounce z-20" style="animation-duration: 4s">
							<div class="bg-[#e0f7fa] p-3 rounded-xl text-[#00bcd4] flex items-center justify-center">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M23 6 13.5 15.5 8.5 10.5 1 18"/><path d="M17 6h6v6"/></svg>
							</div>
							<div>
								<p class="font-black text-deep-navy text-sm">Tăng trưởng SEO</p>
								<p class="text-xs font-semibold text-[#00bcd4]">+250% Traffic</p>
							</div>
						</div>

						<!-- Floating Card 2 -->
						<div class="absolute -top-6 -right-6 bg-white/95 backdrop-blur-md border border-white/50 rounded-2xl p-4 shadow-xl flex items-center gap-4 animate-bounce z-20 hidden md:flex" style="animation-duration: 5s">
							<div class="bg-[#fef3c7] p-3 rounded-xl text-[#ff811b] flex items-center justify-center">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
							</div>
							<div>
								<p class="font-black text-deep-navy text-sm font-sans">Doanh số Quảng cáo</p>
								<p class="text-xs font-semibold text-[#ff811b] font-sans">+180% Đơn hàng</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- About Us Section (Sáng sủa, họa tiết tinh tế) -->
		<section id="about" class="py-20 lg:py-32 bg-white/60 backdrop-blur-sm relative">
			<div class="section-shell grid items-center gap-16 lg:grid-cols-[.9fr_1.1fr] relative z-10">
				<!-- Image Block -->
				<div class="reveal relative">
					<div class="absolute -inset-4 bg-gradient-to-tr from-[#ff37b7]/15 to-[#00bcd4]/15 rounded-3xl blur-2xl"></div>
					<div class="overflow-hidden rounded-2xl aspect-[4/3] w-full shadow-xl border border-white/60 relative z-10 transition-transform duration-500 hover:scale-[1.02]">
						<img class="w-full h-full object-cover" src="/images/team.png" alt="Họp nhóm KIGI Agency" />
					</div>
				</div>
				<!-- Content Block -->
				<div class="reveal space-y-6">
					<div class="tag">Giới thiệu KIGI</div>
					<h2 class="text-3xl font-extrabold tracking-tight text-deep-navy sm:text-4xl leading-tight">
						Đội ngũ trẻ trung, tư duy hiện đại và hành động thực chiến
					</h2>
					<p class="text-slate-600 leading-relaxed text-base md:text-lg">
