---
import Layout from "../layouts/Layout.astro";

const iconAttrs = 'viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"';
const navItems = [
	{ label: "Trang chủ", href: "#top", icon: `<svg ${iconAttrs}><path d="m3 11 9-8 9 8"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/></svg>` },
	{ label: "Về chúng tôi", href: "#about", icon: `<svg ${iconAttrs}><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
	{ label: "Thiết kế Website", href: "#website-design", icon: `<svg ${iconAttrs}><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M8 22h8"/><path d="M12 18v4"/><path d="m8 9 2.2 2.2L8 13.4"/><path d="M14 13h3"/></svg>` },
	{ label: "Quảng cáo Online", href: "#ads-service", icon: `<svg ${iconAttrs}><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>` },
	{ label: "Tuyển dụng", href: "#contact", icon: `<svg ${iconAttrs}><rect x="3" y="7" width="18" height="14" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M12 12v3"/></svg>` },
	{ label: "Liên hệ", href: "#contact", icon: `<svg ${iconAttrs}><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.89.66 2.77a2 2 0 0 1-.45 2.11L8.1 9.9a16 16 0 0 0 6 6l1.3-1.22a2 2 0 0 1 2.11-.45c.88.31 1.81.53 2.77.66A2 2 0 0 1 22 16.92z"/></svg>` },
];

const services = [
	{
		id: "website-design",
		code: "WEB",
		title: "Thiết kế website",
		text: "Website chuẩn thương hiệu, tối ưu giao diện, trải nghiệm người dùng và SEO.",
		accent: "from-[#1280d9] to-[#00c2ff]",
	},
	{
		id: "content-creation",
		code: "SOCIAL",
		title: "Sáng tạo nội dung",
		text: "Lên ý tưởng, viết content, thiết kế hình ảnh, video ngắn và xây dựng kênh social media.",
		accent: "from-[#ff37b7] to-[#ff7bd5]",
	},
	{
		id: "ads-service",
		code: "ADS",
		title: "Chạy quảng cáo",
		text: "Triển khai Facebook Ads, Google Ads, TikTok Ads giúp tăng khách hàng tiềm năng.",
		accent: "from-[#ffd21e] to-[#ff9f1c]",
	},
	{
		id: "brand-service",
		code: "BRAND",
		title: "Xây dựng thương hiệu",
		text: "Thiết kế nhận diện, định vị thương hiệu và concept truyền thông khác biệt.",
		accent: "from-[#7c3cff] to-[#1280d9]",
	},
];

const reasons = [
	["Tăng trưởng thật", "Tập trung chuyển đổi và hiệu quả kinh doanh."],
	["Đúng khách hàng", "Tiếp cận đúng tệp mục tiêu."],
	["Bắt trend nhanh", "Nội dung trẻ trung, dễ viral."],
	["Ý tưởng mới", "Concept sáng tạo theo từng ngành."],
];

const workflow = [
	["01", "Tiếp nhận", "Lắng nghe nhu cầu và mục tiêu."],
	["02", "Chiến lược", "Xây dựng kế hoạch phù hợp."],
	["03", "Triển khai", "Sản xuất nội dung và quảng cáo."],
	["04", "Tối ưu", "Theo dõi dữ liệu và cải thiện."],
];

const featuredServices = [
	{
		title: "Quản lý Fanpage",
		items: ["Lên kế hoạch nội dung", "Thiết kế hình ảnh chuyên nghiệp", "Tăng tương tác thương hiệu", "Đăng bài và chăm sóc fanpage"],
	},
	{
		title: "Marketing tổng thể",
		popular: true,
		items: ["Facebook & Google Ads", "Xây dựng thương hiệu", "Quản lý nội dung đa nền tảng", "Báo cáo & tối ưu hàng tháng"],
	},
	{
		title: "Media & Video",
		items: ["Quay dựng video TikTok", "Video quảng cáo thương hiệu", "Chụp ảnh sản phẩm", "Viral content ngắn"],
	},
];

const commitments = [
	["Triển khai nhanh", "Hỗ trợ setup và triển khai chiến dịch chỉ trong vài ngày."],
	["Tối ưu hiệu quả", "Liên tục theo dõi và tối ưu quảng cáo để tăng chuyển đổi."],
	["Đồng hành lâu dài", "Tư vấn chiến lược phát triển thương hiệu bền vững."],
];

const projects = [
	["Mỹ phẩm", "Chiến dịch Facebook", "https://images.unsplash.com/photo-1493612276216-ee3925520721?q=80&w=1200&auto=format&fit=crop"],
	["Thời trang", "Xây dựng TikTok", "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?q=80&w=1200&auto=format&fit=crop"],
	["Ẩm thực", "Quảng cáo tăng doanh số", "https://images.unsplash.com/photo-1519389950473-47ba0277781c?q=80&w=1200&auto=format&fit=crop"],
	["Công nghệ", "Website & SEO", "https://images.unsplash.com/photo-1504384308090-c894fdcc538d?q=80&w=1200&auto=format&fit=crop"],
];

const clients = ["NHA TRANG FOOD", "VIET SMILE", "KATI BEAUTY", "SÀI GÒN MEDIA", "VIỆT PHÁT GROUP", "NICE TRAVEL"];
const serviceList = ["Thiết kế Website chuẩn SEO", "Quản lý Fanpage", "Sáng tạo nội dung Social", "Chạy quảng cáo Facebook / Google", "Media & Video TikTok"];
const contactItems = [
	{ label: "Hotline", text: "0563.555.535", href: "tel:0563555535", icon: `<svg ${iconAttrs}><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.89.66 2.77a2 2 0 0 1-.45 2.11L8.1 9.9a16 16 0 0 0 6 6l1.3-1.22a2 2 0 0 1 2.11-.45c.88.31 1.81.53 2.77.66A2 2 0 0 1 22 16.92z"/></svg>` },
	{ label: "Email", text: "info@kigiagency.com", href: "mailto:info@kigiagency.com", icon: `<svg ${iconAttrs}><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>` },
	{ label: "Website", text: "www.kigiagency.com", href: "https://kigiagency.com/", icon: `<svg ${iconAttrs}><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 0 20"/><path d="M12 2a15.3 15.3 0 0 0 0 20"/></svg>` },
	{ label: "Địa chỉ", text: "Số 25 - 26 Nguyễn Đình Chiểu, Phường Bắc Nha Trang, Tỉnh Khánh Hòa", href: "", icon: `<svg ${iconAttrs}><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>` },
];
---

<Layout>
	<main id="top">
		<header class="fixed left-0 right-0 top-0 z-50 px-4 py-4">
			<div class="mx-auto max-w-7xl rounded-[10px] border border-[#1280d9]/10 bg-white/92 px-4 py-3 text-[#0b172a] shadow-xl shadow-[#1280d9]/10 backdrop-blur-xl lg:px-6">
				<div class="flex items-center justify-between gap-4">
				<a href="#top" class="button-focus flex items-center gap-3 rounded-[10px]">
					<span class="grid size-11 place-items-center rounded-[10px] bg-[#1280d9] font-black text-white shadow-lg shadow-[#1280d9]/25">K</span>
					<span class="leading-none">
						<span class="block text-xl font-black tracking-[0.12em]">KIGI</span>
						<span class="mt-1 block text-[11px] font-bold uppercase tracking-[0.26em] text-[#1280d9]">Agency</span>
					</span>
				</a>
				<nav class="hidden items-center gap-1 text-[12px] font-black uppercase tracking-[0.04em] 2xl:flex">
					{navItems.map((item) => (
						<a class="button-focus flex items-center gap-2 rounded-[10px] px-2.5 py-3 text-[#0b172a]/72 transition hover:bg-[#e8f4ff] hover:text-[#1280d9]" href={item.href}>
							<span class="menu-icon" set:html={item.icon}></span>
							<span class="whitespace-nowrap">{item.label}</span>
						</a>
					))}
				</nav>
				<div class="flex items-center gap-2">
				<a href="#contact" class="button-focus inline-flex rounded-[10px] bg-[#1280d9] px-4 py-3 text-xs font-black text-white shadow-lg shadow-[#1280d9]/25 transition hover:-translate-y-0.5 hover:bg-[#0f6fc0] sm:px-5 sm:text-sm">
					<span class="hidden sm:inline">Nhận tư vấn</span><span class="sm:hidden">Tư vấn</span>
				</a>
				<button class="button-focus menu-toggle grid size-11 place-items-center rounded-[10px] border border-[#1280d9]/15 bg-[#e8f4ff] text-[#1280d9] 2xl:hidden" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Mở menu">
					<svg viewBox="0 0 24 24" class="size-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
						<path d="M4 7h16"></path>
						<path d="M4 12h16"></path>
						<path d="M4 17h16"></path>
					</svg>
				</button>
				</div>
				</div>
				<nav id="mobile-menu" class="mobile-menu hidden border-t border-[#1280d9]/10 pt-3 2xl:hidden">
					<div class="grid gap-2 sm:grid-cols-2 xl:grid-cols-3">
						{navItems.map((item) => (
							<a class="button-focus flex items-center gap-3 rounded-[10px] bg-[#f3f9ff] px-4 py-3 text-sm font-black uppercase tracking-[0.04em] text-[#0b172a] transition hover:bg-[#1280d9] hover:text-white" href={item.href}>
								<span class="menu-icon" set:html={item.icon}></span>
								<span>{item.label}</span>
							</a>
						))}
					</div>
				</nav>
			</div>
		</header>

		<section class="relative overflow-hidden bg-[linear-gradient(135deg,#f7fbff_0%,#eef7ff_42%,#fff8fe_100%)] pb-16 pt-32 lg:pb-24 lg:pt-36">
			<div class="absolute inset-0 opacity-80" style="background-image: radial-gradient(circle at 16% 18%, rgba(18,128,217,.16), transparent 28%), radial-gradient(circle at 86% 20%, rgba(255,55,183,.13), transparent 30%), linear-gradient(115deg, transparent 0 38%, rgba(255,210,30,.18) 38% 46%, transparent 46%);"></div>
			<div class="section-shell relative grid items-center gap-10 lg:grid-cols-[1.02fr_.98fr]">
				<div class="reveal">
					<p class="tag text-[#1280d9]">KIGI Agency</p>
					<h1 class="mt-6 max-w-3xl text-balance text-[clamp(2.55rem,5.4vw,5.6rem)] font-black leading-[1.02] tracking-normal text-[#0b172a]">
						Sáng tạo để tăng trưởng bền vững
					</h1>
					<p class="mt-6 max-w-2xl text-base leading-8 text-[#385069] md:text-lg">
						KIGI Agency giúp doanh nghiệp xây dựng thương hiệu mạnh mẽ trên Facebook, TikTok, Google và Website bằng tư duy sáng tạo, chiến lược thực chiến và nội dung đậm chất GenZ.
					</p>
					<div class="mt-8 flex flex-wrap gap-3">
						<a class="button-focus rounded-[10px] bg-[#1280d9] px-6 py-4 text-sm font-black text-white shadow-xl shadow-[#1280d9]/20 transition hover:-translate-y-1 hover:bg-[#0f6fc0]" href="#services">Khám phá dịch vụ</a>
						<a class="button-focus rounded-[10px] border border-[#1280d9]/20 bg-white px-6 py-4 text-sm font-black text-[#1280d9] transition hover:-translate-y-1 hover:border-[#1280d9]" href="#projects">Xem dự án</a>
					</div>
					<div class="mt-10 grid max-w-xl grid-cols-3 gap-3">
						{[
							["50+", "Doanh nghiệp"],
							["4+", "Nhóm dịch vụ"],
							["24/7", "Đồng hành"],
						].map(([number, label]) => (
							<div class="rounded-[10px] border border-[#1280d9]/10 bg-white/75 p-4 shadow-lg shadow-[#1280d9]/5">
								<p class="text-2xl font-black text-[#1280d9]">{number}</p>
								<p class="mt-1 text-xs font-bold uppercase tracking-[0.06em] text-[#385069]">{label}</p>
							</div>
						))}
					</div>
				</div>

				<div class="reveal relative" style="transition-delay: 120ms">
					<div class="relative mx-auto max-w-[560px] rounded-[10px] border border-[#1280d9]/10 bg-white p-3 shadow-2xl shadow-[#1280d9]/18">
						<img class="aspect-[4/3] w-full rounded-[10px] object-cover" src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1400&auto=format&fit=crop" alt="Đội ngũ trẻ KIGI Agency" />
						<div class="absolute -bottom-6 left-6 right-6 rounded-[10px] border border-[#1280d9]/10 bg-white p-5 shadow-xl shadow-[#1280d9]/12">
							<p class="text-xs font-black uppercase tracking-[0.12em] text-[#1280d9]">Giải pháp Marketing toàn diện</p>
							<p class="mt-2 text-2xl font-black leading-tight text-[#0b172a]">Sáng tạo khác biệt, đo lường rõ ràng</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="about" class="py-16 lg:py-24">
			<div class="section-shell grid items-center gap-10 lg:grid-cols-[.9fr_1.1fr]">
				<div class="reveal">
					<img class="aspect-[4/3] w-full rounded-[10px] object-cover shadow-2xl shadow-[#1280d9]/10" src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1400&auto=format&fit=crop" alt="KIGI teamwork" />
				</div>
				<div class="reveal">
					<p class="tag text-[#1280d9]">Giới thiệu KIGI</p>
					<h2 class="mt-5 text-balance text-3xl font-black leading-tight text-[#0b172a] md:text-5xl">Agency trẻ trung, sáng tạo và thực chiến</h2>
					<p class="mt-6 text-base leading-8 text-[#385069] md:text-lg">
						KIGI Agency đồng hành cùng doanh nghiệp xây dựng thương hiệu, phát triển nội dung, thiết kế website và triển khai quảng cáo đa nền tảng. Chúng tôi tập trung vào hiệu quả thật: tăng nhận diện, tăng khách hàng tiềm năng và tăng doanh thu.
					</p>
				</div>
			</div>
		</section>

		<section class="overflow-hidden border-y border-[#1280d9]/10 bg-white py-4">
			<div class="marquee gap-10 whitespace-nowrap text-sm font-black uppercase tracking-[0.12em] text-[#1280d9]">
				{Array.from({ length: 2 }).map(() => (
					<div class="flex gap-10">
						<span>Agency sáng tạo</span><span>Marketing Facebook</span><span>TikTok Viral</span><span>Quảng cáo Google</span><span>Xây dựng thương hiệu</span><span>Thiết kế website</span><span>SEO</span><span>Sản xuất media</span><span>KIGI Agency</span>
					</div>
				))}
			</div>
		</section>

		<section id="services" class="py-16 lg:py-24">
			<div class="section-shell">
				<div class="reveal flex flex-col justify-between gap-6 md:flex-row md:items-end">
					<div>
						<p class="tag text-[#1280d9]">Dịch vụ của chúng tôi</p>
						<h2 class="mt-5 text-balance text-3xl font-black leading-tight text-[#0b172a] md:text-5xl">Giải pháp Marketing toàn diện</h2>
					</div>
					<a href="#contact" class="button-focus w-fit rounded-[10px] border border-[#1280d9]/25 bg-white px-5 py-3 text-sm font-black text-[#1280d9] transition hover:bg-[#1280d9] hover:text-white">Nhận tư vấn dịch vụ</a>
				</div>
				<div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
					{services.map((service, index) => (
						<article id={service.id} class="reveal k-card group overflow-hidden p-0 transition hover:-translate-y-1 hover:border-[#1280d9]/35 hover:shadow-2xl hover:shadow-[#1280d9]/12" style={`transition-delay: ${index * 70}ms`}>
							<div class={`h-2 bg-gradient-to-r ${service.accent}`}></div>
							<div class="p-6">
							<div class={`inline-flex rounded-[10px] bg-gradient-to-r px-3 py-2 text-xs font-black text-white ${service.accent}`}>{service.code}</div>
							<h3 class="mt-6 text-xl font-black text-[#0b172a]">{service.title}</h3>
							<p class="mt-4 leading-7 text-[#385069]">{service.text}</p>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="relative overflow-hidden bg-[#0b172a] py-16 text-white lg:py-24">
			<div class="absolute inset-0 opacity-70" style="background-image: radial-gradient(circle at 12% 20%, rgba(18,128,217,.34), transparent 28%), radial-gradient(circle at 88% 12%, rgba(255,55,183,.22), transparent 30%), linear-gradient(120deg, transparent 0 55%, rgba(255,210,30,.12) 55% 62%, transparent 62%);"></div>
			<div class="section-shell relative">
				<div class="reveal text-center">
					<p class="tag border-white/15 bg-white/92 text-[#1280d9] before:bg-[#1280d9]">Vì sao chọn KIGI?</p>
					<h2 class="mx-auto mt-5 max-w-3xl text-balance text-3xl font-black leading-tight md:text-5xl">Khác biệt từ tư duy thực chiến</h2>
				</div>
				<div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
					{reasons.map(([title, text], index) => (
						<article class="reveal rounded-[10px] border border-white/14 bg-white/[0.09] p-6 shadow-xl shadow-black/10" style={`transition-delay: ${index * 70}ms`}>
							<p class={`w-fit rounded-[10px] px-3 py-2 text-sm font-black ${index === 1 ? "bg-[#ff37b7]" : index === 2 ? "bg-[#ffd21e] text-[#0b172a]" : "bg-[#1280d9]"}`}>0{index + 1}</p>
							<h3 class="mt-6 text-xl font-black">{title}</h3>
							<p class="mt-3 leading-7 text-white/68">{text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="py-16 lg:py-24">
			<div class="section-shell">
				<div class="reveal max-w-3xl">
					<p class="tag text-[#1280d9]">Quy trình làm việc</p>
					<h2 class="mt-5 text-balance text-3xl font-black leading-tight text-[#0b172a] md:text-5xl">4 bước triển khai hiệu quả</h2>
				</div>
				<div class="mt-10 grid gap-4 lg:grid-cols-4">
					{workflow.map(([number, title, text], index) => (
						<article class="reveal k-card relative overflow-hidden p-6" style={`transition-delay: ${index * 70}ms`}>
							<span class="absolute -right-2 -top-4 text-7xl font-black text-[#1280d9]/8">{number}</span>
							<p class="text-sm font-black uppercase tracking-[0.14em] text-[#1280d9]">{number}</p>
							<h3 class="mt-10 text-xl font-black text-[#0b172a]">{title}</h3>
							<p class="mt-3 leading-7 text-[#385069]">{text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white py-16 lg:py-24">
			<div class="section-shell">
				<div class="reveal text-center">
					<p class="tag text-[#1280d9]">Dịch vụ nổi bật</p>
					<h2 class="mx-auto mt-5 max-w-4xl text-balance text-3xl font-black leading-tight text-[#0b172a] md:text-5xl">Giải pháp giúp doanh nghiệp tăng trưởng mạnh</h2>
				</div>
				<div class="mt-10 grid gap-6 lg:grid-cols-3">
					{featuredServices.map((item, index) => (
						<article class={`reveal k-card relative p-7 ${item.popular ? "border-2 border-[#1280d9]" : ""}`} style={`transition-delay: ${index * 80}ms`}>
							{item.popular && <span class="absolute right-4 top-4 rounded-[10px] bg-[#1280d9] px-3 py-1 text-xs font-black text-white">PHỔ BIẾN</span>}
							<p class="text-sm font-black uppercase tracking-[0.12em] text-[#1280d9]">Gói {index + 1}</p>
							<h3 class="mt-5 text-2xl font-black text-[#0b172a]">{item.title}</h3>
							<ul class="mt-6 space-y-4 text-[#385069]">
								{item.items.map((point) => (
									<li class="flex gap-3"><span class="mt-1 size-2 shrink-0 rounded-full bg-[#1280d9]"></span><span>{point}</span></li>
								))}
							</ul>
						</article>
					))}
				</div>
